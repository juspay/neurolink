{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "sveltekit",
  "redirects": [
    {
      "source": "/discord",
      "destination": "https://discord.com/channels/1461226459774451726",
      "permanent": false
    },
    {
      "source": "/docs/:path*",
      "destination": "https://docs.neurolink.ink/docs/:path*",
      "permanent": true
    },
    {
      "source": "/sdk/:path*",
      "destination": "https://docs.neurolink.ink/docs/sdk/:path*",
      "permanent": true
    },
    {
      "source": "/cli/:path*",
      "destination": "https://docs.neurolink.ink/docs/cli/:path*",
      "permanent": true
    },
    {
      "source": "/getting-started",
      "destination": "https://docs.neurolink.ink/docs/getting-started",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy-Report-Only",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://connect.facebook.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; connect-src 'self' https://www.google-analytics.com https://www.facebook.com"
        }
      ]
    },
    {
      "source": "/_app/immutable/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.+\\.(?:ico|png|jpg|jpeg|gif|svg|webp|woff2?|ttf|eot))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    }
  ]
}
