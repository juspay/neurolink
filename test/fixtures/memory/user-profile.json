  "templateModeExamples": {
    "description": "Examples of template-based working memory (Markdown format)",
    "templates": [
      {
        "name": "developer_template",
        "template": "# User Profile: {{name}}\n\n## Role\n{{role}} at {{department}}\n\n## Expertise\n{{#each expertise}}\n- {{this}}\n{{/each}}\n\n## Preferences\n- Code Style: {{preferences.codeStyle}}\n- Framework: {{preferences.framework}}\n- Response Format: {{preferences.responseFormat}}"
      },
      {
        "name": "simple_template",
        "template": "Name: {{name}}\nRole: {{role}}\nPreferences: {{preferences.responseFormat}}"
      }
    ]
  },

  "schemaModeExamples": {
    "description": "Examples of schema-based working memory (Zod/JSON Schema)",
    "schemas": [
      {
        "name": "basic_user_schema",
        "zodDefinition": "z.object({ name: z.string(), email: z.string().email(), age: z.number().optional() })",
        "jsonSchema": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "age": { "type": "integer", "minimum": 0 }
          },
          "required": ["name", "email"]
        }
      },
      {
        "name": "preferences_schema",
        "zodDefinition": "z.object({ theme: z.enum(['light', 'dark']), language: z.string(), notifications: z.boolean() })",
        "jsonSchema": {
          "type": "object",
          "properties": {
            "theme": { "type": "string", "enum": ["light", "dark"] },
            "language": { "type": "string" },
            "notifications": { "type": "boolean" }
          },
          "required": ["theme", "language", "notifications"]
        }
      }
    ]
  },

  "testCases": {
    "getProfile": {
      "description": "Test retrieving user profile",
      "input": {
        "userId": "user-dev-001"
      },
      "expected": {
        "profileFound": true,
        "hasData": true,
        "dataContains": ["name", "role", "expertise"]
      }
    },

    "updateProfile": {
      "description": "Test updating user profile data",
      "input": {
        "userId": "user-dev-001",
        "updates": {
          "recentProjects": [
            {
              "name": "New Project",
              "role": "Lead Developer",
              "technologies": ["Go", "Kubernetes"]
            }
          ]
        }
      },
      "expected": {
        "updated": true,
        "versionIncremented": true
      }
    },

    "createProfile": {
      "description": "Test creating new user profile",
      "input": {
        "userId": "user-new-001",
        "data": {
          "name": "New Test User",
          "role": "Junior Developer"
        }
      },
      "expected": {
        "created": true,
        "version": 1
      }
    },

    "deleteProfile": {
      "description": "Test deleting user profile",
      "input": {
        "userId": "user-to-delete"
      },
      "expected": {
        "deleted": true,
        "notFoundAfterDelete": true
      }
    },

    "schemaValidation": {
      "description": "Test schema validation for schema-mode profiles",
      "validInput": {
        "userId": "user-schema-001",
        "data": {
          "name": "Valid User",
          "email": "valid@example.com",
          "experienceLevel": "intermediate"
        }
      },
      "invalidInput": {
        "userId": "user-schema-001",
        "data": {
          "name": "Invalid User",
          "email": "not-an-email",
          "experienceLevel": "not-a-valid-level"
        }
      },
      "expected": {
        "validInputAccepted": true,
        "invalidInputRejected": true,
        "errorContains": "validation"
      }
    },

    "templateRendering": {
      "description": "Test template rendering with profile data",
      "input": {
        "userId": "user-dev-001",
        "templateName": "developer_template"
      },
      "expected": {
        "renderedContains": [
          "Alex Chen",
          "Senior Software Engineer",
          "TypeScript"
        ]
      }
    }
  },

  "tokenAllocation": {
    "description": "Working memory token allocation settings",
    "defaultAllocation": 0.15,
    "maxTokens": 2000,
    "truncationStrategy": "preserve_recent"
  }
}
