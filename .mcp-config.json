{
  "mcpServers": {
    "filesystem": {
      "name": "filesystem",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "transport": "stdio"
    },
    "github": {
      "name": "github",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "transport": "stdio"
    },
    "brave-search": {
      "name": "brave-search",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "transport": "stdio"
    },
    "bitbucket": {
      "name": "bitbucket",
      "command": "npx",
      "args": ["-y", "@nexus2520/bitbucket-mcp-server"],
      "transport": "stdio",
      "env": {
        "BITBUCKET_USERNAME": "demo-user",
        "BITBUCKET_APP_PASSWORD": "demo-password-123"
      }
    }
  },
  "autoDiscovery": {
    "enabled": true,
    "autoRegister": true
  },
  "defaultRegistry": {
    "enabled": true,
    "includeBuiltInTools": true
  }
}
