# AI Provider Configuration
AI_DEFAULT_PROVIDER="bedrock"
AI_FALLBACK_PROVIDER="vertex"
AI_STREAMING_PROVIDER="vercelSdk"

# OpenAI Configuration
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_MODEL="gpt-4o"

# Gemini Configuration
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_API_MODEL="gemini-2.5-flash-preview-05-20"

# Google Vertex AI Configuration
GOOGLE_APPLICATION_CREDENTIALS=""
GOOGLE_VERTEX_PROJECT="your-project-id"
GOOGLE_VERTEX_LOCATION="us-east5"
GOOGLE_GENERATIVE_AI_API_KEY="your_google_generative_ai_api_key_here"
VERTEX_MODEL_ID="claude-sonnet-4@20250514"

# Amazon Bedrock Configuration
AWS_ACCESS_KEY_ID="your_aws_access_key_id"
AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key"
AWS_SESSION_TOKEN="your_aws_session_token_optional"
AWS_REGION="us-east-2"
BEDROCK_MODEL_ID="arn:aws:bedrock:us-east-2:account:inference-profile/us.anthropic.claude-3-7-sonnet-20250219-v1:0"

# Claude Configuration
CLAUDE_MODEL_ARN="arn:aws:bedrock:us-east-2:account:inference-profile/us.anthropic.claude-3-7-sonnet-20250219-v1:0"
AI_MODEL_REGION="us-east-2"

# Application Configuration
PUBLIC_APP_URL="http://localhost:5173"
PUBLIC_APP_NAME="neurolink"
PUBLIC_APP_ENVIRONMENT="dev"
