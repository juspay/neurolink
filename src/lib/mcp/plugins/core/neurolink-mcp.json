{
  "name": "@neurolink-mcp/filesystem",
  "version": "1.0.0",
  "main": "./filesystem-mcp.js",
  "description": "Provides secure file system operations for NeuroLink agents",
  "author": "NeuroLink Team",
  "license": "MIT",
  "engine": {
    "neurolink": ">=1.9.0 <2.0.0"
  },
  "permissions": [
    "fs:read:./**/*",
    "fs:write:./output/**/*",
    "fs:write:./temp/**/*"
  ],
  "keywords": ["filesystem", "file", "mcp", "plugin"]
}
