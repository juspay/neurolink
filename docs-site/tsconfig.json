{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "downlevelIteration": true,
    "baseUrl": ".",
    "paths": {
      "@site/*": ["./*"],
      "@components/*": ["./src/components/*"],
      "@docusaurus/*": ["./node_modules/@docusaurus/*"],
      "@generated/*": ["./.docusaurus/*"]
    },
    "types": ["@docusaurus/module-type-aliases", "@docusaurus/types", "node"]
  },
  "include": [
    "src/**/*",
    "config/**/*",
    "scripts/**/*",
    "docusaurus.config.ts",
    "sidebars.ts",
    "babel.config.js"
  ],
  "exclude": ["node_modules", "build", ".docusaurus", "mcp-server"]
}
