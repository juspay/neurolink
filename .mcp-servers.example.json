{
  "mcpServers": {
    "filesystem": {
      "name": "filesystem",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/"],
      "transport": "stdio",
      "description": "File and directory operations"
    },
    "github": {
      "name": "github",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "transport": "stdio",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_your_token_here"
      },
      "description": "GitHub repository management"
    },
    "puppeteer": {
      "name": "puppeteer",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "transport": "stdio",
      "description": "Browser automation and web scraping"
    },
    "brave-search": {
      "name": "brave-search",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "transport": "stdio",
      "env": {
        "BRAVE_API_KEY": "your_brave_api_key_here"
      },
      "description": "Web search capabilities"
    },
    "fetch": {
      "name": "fetch",
      "command": "python",
      "args": ["-m", "mcp_server_fetch"],
      "transport": "stdio",
      "description": "Fetch web content and convert to markdown"
    },
    "git": {
      "name": "git",
      "command": "python",
      "args": ["-m", "mcp_server_git"],
      "transport": "stdio",
      "description": "Git repository operations"
    },
    "custom-python-server": {
      "name": "custom-python-server",
      "command": "python",
      "args": ["/path/to/your/custom-server.py"],
      "transport": "stdio",
      "env": {
        "CUSTOM_API_KEY": "your_api_key",
        "DEBUG": "true"
      },
      "cwd": "/path/to/project/directory",
      "description": "Example custom Python MCP server"
    },
    "custom-nodejs-server": {
      "name": "custom-nodejs-server",
      "command": "node",
      "args": ["/path/to/your/server.js"],
      "transport": "stdio",
      "env": {
        "NODE_ENV": "production",
        "PORT": "8080"
      },
      "description": "Example custom Node.js MCP server"
    },
    "sse-web-server": {
      "name": "sse-web-server",
      "command": "http://localhost:8080",
      "transport": "sse",
      "url": "http://localhost:8080/sse",
      "description": "Example SSE-based web MCP server"
    },
    "docker-server": {
      "name": "docker-server",
      "command": "docker",
      "args": ["run", "--rm", "-i", "my-mcp-server:latest"],
      "transport": "stdio",
      "description": "Example Docker-based MCP server"
    }
  },
  "globalConfig": {
    "timeout": 30000,
    "retries": 3,
    "logLevel": "info",
    "enableDebug": false
  },
  "metadata": {
    "version": "1.0.0",
    "description": "NeuroLink MCP Server Configuration",
    "lastUpdated": "2025-01-09",
    "documentation": "https://github.com/juspay/neurolink/docs/MCP-INTEGRATION.md"
  }
}
