# Amazon SageMaker Provider Configuration
# Copy this file to .env and update with your actual values

# AWS Credentials (Required)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1

# Optional: Session token for temporary credentials
# AWS_SESSION_TOKEN=your_session_token_here

# SageMaker Configuration
SAGEMAKER_DEFAULT_ENDPOINT=your-sagemaker-endpoint-name
SAGEMAKER_MODEL_NAME=your-model-name

# Optional: Advanced Configuration
SAGEMAKER_TIMEOUT=30000
SAGEMAKER_MAX_RETRIES=3
SAGEMAKER_MODEL_TYPE=custom

# Optional: Custom SageMaker Endpoint URL
# SAGEMAKER_ENDPOINT=https://custom-sagemaker-endpoint.amazonaws.com

# Development/Testing Endpoints (Optional)
SAGEMAKER_TEST_ENDPOINT=test-endpoint-name
SAGEMAKER_DEV_ENDPOINT=dev-endpoint-name

# Environment-specific credentials (Optional)
# DEV_AWS_ACCESS_KEY_ID=dev_access_key
# DEV_AWS_SECRET_ACCESS_KEY=dev_secret_key
# STAGING_AWS_ACCESS_KEY_ID=staging_access_key
# STAGING_AWS_SECRET_ACCESS_KEY=staging_secret_key
# PROD_AWS_ACCESS_KEY_ID=prod_access_key
# PROD_AWS_SECRET_ACCESS_KEY=prod_secret_key
# PROD_AWS_REGION=us-east-1
# PROD_SAGEMAKER_ENDPOINT=production-endpoint-name

# Debugging (Optional)
# NODE_ENV=development
# DEBUG=neurolink:sagemaker:*